# Admin Dashboard Configuration
# IMPORTANT: Replace these with strong, unique values in production
ADMIN_EMAIL=your-admin-email@example.com
ADMIN_PASSWORD=your-strong-password-here
ADMIN_AUTH_TOKEN=your-secure-random-token-here

# Email Configuration (for form submission notifications)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Supabase Configuration
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# In production, use strong, unique values for these variables
